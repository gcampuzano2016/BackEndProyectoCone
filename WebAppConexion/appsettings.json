{
    "ConnectionStrings": {
        "Conexion": ""
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft": "Warning",
            "Microsoft.Hosting.Lifetime": "Information"
        }
    },
    "AllowedHosts": "app.conexionecuador.com;localhost",
    "Jwt": {
        "Key": "",
        "Issuer": ""
    },
    "IpRateLimiting": {
        "EnableEndpointRateLimiting": true,
        "StackBlockedRequests": false,
        "RealIpHeader": "X-Real-IP",
        "ClientIdHeader": "X-ClientId",
        "HttpStatusCode": 429,
        "GeneralRules": [
            {
                "Endpoint": "POST:/api/EnviarNotificacion/ActualizarClaveEmpleado",
                "Period": "1m",
                "Limit": 5
            },
            {
                "Endpoint": "POST:/api/Login/Login",
                "Period": "1m",
                "Limit": 10
            }
        ]
    }
}
